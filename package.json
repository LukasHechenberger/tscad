{
  "name": "tscad",
  "version": "0.0.0",
  "private": true,
  "description": "A modern CAD modeller for programmers",
  "keywords": [],
  "homepage": "https://tscad.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LukasHechenberger/tscad.git"
  },
  "license": "MIT",
  "author": "Lukas Hechenberger <npm@ls-age.com> (https://ls-age.com/)",
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "examples/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "22.19.1",
      "@types/react": "^19.2.6",
      "@types/react-dom": "^19.2.3",
      "eslint": "9.39.1",
      "publint": "0.3.15",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "typescript": "5.9.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "check:format": "prettier --check .",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "ignore-sync": "ignore-sync .",
    "lint": "turbo run lint",
    "prepare": "toolsync prepare --config toolsync.json && ignore-sync .",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@repo/toolsync-plugin": "workspace:*",
    "@toolsync/builtin": "^0.5.1",
    "@toolsync/cli": "0.3.1",
    "ignore-sync": "^8.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.19",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.6.1"
  },
  "packageManager": "bun@1.3.10"
}
